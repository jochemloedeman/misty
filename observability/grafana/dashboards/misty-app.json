    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "Refresh cycle",
      "type": "row",
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Wall-clock duration of a full RefreshAll cycle, from the histogram buckets.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(refresh_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(refresh_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(refresh_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ],
      "title": "Cycle duration (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Share of refresh cycles that ended in error.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "pluginVersion": "13.0.1",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(sum(increase(refresh_duration_seconds_count{error_type=\"refresh_failed\"}[$__range])) or vector(0)) / clamp_min(sum(increase(refresh_duration_seconds_count[$__range])), 1)", "refId": "A" }
      ],
      "title": "Cycle failure ratio",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Average cycle duration (rate of sum / rate of count).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
      "id": 10,
      "options": {
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "pluginVersion": "13.0.1",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(refresh_duration_seconds_sum[$__range])) / clamp_min(sum(increase(refresh_duration_seconds_count[$__range])), 1)", "refId": "A" }
      ],
      "title": "Mean cycle duration",
      "type": "stat"
    },
    {
